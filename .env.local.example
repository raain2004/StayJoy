# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Knowledge Base API (tự đặt — dùng cho n8n gọi endpoint)
KNOWLEDGE_BASE_API_KEY=stayjoy-kb-secret-2024

# LLM — chỉ cần key của provider bạn dùng
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# LLM Config (optional — có thể cấu hình qua admin UI thay vì env)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash-lite
LLM_FALLBACK_PROVIDER=
